# ──────────────────────────────────────────────────────────────
# .gitignore for medmanage-web (Next.js)
# ──────────────────────────────────────────────────────────────

# ── SECRETS — NEVER commit these ──────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env*.local
*.pem
*.key
secrets/
*secret*
*credentials*
service-account*.json
firebase-adminsdk*.json

# ── Dependencies ───────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js build output ───────────────────────────────────────
/.next/
/out/
/build

# ── Testing ────────────────────────────────────────────────────
/coverage

# ── Vercel ─────────────────────────────────────────────────────
.vercel

# ── TypeScript ─────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS / Editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea/

# ── Logs ───────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
